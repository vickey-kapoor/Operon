# ── Required ─────────────────────────────────────────────────────────────────
# Gemini API key (get one at https://aistudio.google.com/apikey)
# Either name is accepted; GEMINI_API_KEY takes precedence.
GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Anthropic (optional — used when planner/verifier provider = "anthropic") ──
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1/messages

# ── Auth & Security ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the X-API-Key header.
# Leave empty to disable auth (development only).
# API_KEYS=your-key-1,your-key-2
API_KEYS=

# Comma-separated list of allowed CORS origins.
# Default is chrome-extension://* only (restrictive, NOT wildcard).
# Set explicitly in production.
# Example: CORS_ORIGINS=*,https://myapp.com,chrome-extension://abcdef123
CORS_ORIGINS=

# Rate limit in requests per minute per API key (default 60).
RATE_LIMIT_RPM=60

# ── Browser ───────────────────────────────────────────────────────────────────
# Run Chromium in headless mode. Set to "false" to see the browser window.
BROWSER_HEADLESS=true
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# ── Agent ─────────────────────────────────────────────────────────────────────
# Maximum number of concurrent browser sessions.
MAX_CONCURRENT_TASKS=5

# ── Persistence ───────────────────────────────────────────────────────────────
# Task store backend: "memory" (default) or "firestore".
TASK_STORE=memory

# ── GCP (deploy only) ────────────────────────────────────────────────────────
# Required for Cloud Run deployment and GCP integrations.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# GCS bucket for screenshot uploads (optional).
GCS_BUCKET=

# ── Vertex AI (optional — alternative to Gemini API key) ─────────────────────
# Set OPERON_USE_VERTEX=true to use Application Default Credentials instead.
# OPERON_USE_VERTEX=false
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# ── Model selection ───────────────────────────────────────────────────────────
# Global Gemini model default (used when no mode-specific model is set).
GEMINI_MODEL=gemini-2.5-flash

# Desktop loop — backend options: json | combined
# Planner/verifier provider options: gemini | anthropic
OPERON_DESKTOP_BACKEND=json
OPERON_DESKTOP_MODEL=gemini-3-flash-preview
OPERON_DESKTOP_FALLBACK_MODEL=gemini-2.5-flash
OPERON_DESKTOP_VERIFIER_MODEL=gemini-3-flash-preview
OPERON_DESKTOP_VERIFIER_PROVIDER=gemini
# OPERON_DESKTOP_PLANNER_PROVIDER=gemini
# OPERON_DESKTOP_PLANNER_MODEL=

# Browser loop — backend options: computer_use | json | combined | browserbase
# Planner/verifier provider options: gemini | anthropic
OPERON_BROWSER_BACKEND=computer_use
OPERON_BROWSER_MODEL=gemini-2.5-computer-use-preview-10-2025
OPERON_BROWSER_FALLBACK_BACKEND=json
OPERON_BROWSER_FALLBACK_MODEL=gemini-3-flash-preview
OPERON_BROWSER_VERIFIER_MODEL=gemini-3-flash-preview
OPERON_BROWSER_VERIFIER_PROVIDER=gemini
# OPERON_BROWSER_PLANNER_PROVIDER=gemini
# OPERON_BROWSER_PLANNER_MODEL=

# ── HITL Webhook (optional) ───────────────────────────────────────────────────
# POST endpoint called when the agent pauses for human intervention.
# Payload: { event, run_id, intent, page_hint, message, url }
HITL_WEBHOOK_URL=

# ── Browserbase (optional) ────────────────────────────────────────────────────
# Set OPERON_BROWSER_BACKEND=browserbase to use Browserbase cloud sessions.
# Install the extra first: pip install -e ".[browserbase]"
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Observability ─────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default INFO).
LOG_LEVEL=INFO

# Set to 1 to emit detailed step trace events to stdout (loop debugging).
# OPERON_TRACE=1

# ── Testing / Safe mode ───────────────────────────────────────────────────────
# Set to true to skip hardware baseline validation and desktop resets in tests.
# OPERON_TEST_SAFE_MODE=false

# ── Session limits ────────────────────────────────────────────────────────────
# Inactive session cleanup threshold in seconds (default 1800 = 30 min).
MAX_SESSION_DURATION=1800

# Max retries before injecting a "stuck" hint (default 3).
MAX_RETRIES=3

# Hard timeout (seconds) for the entire action loop (default 120).
ACTION_LOOP_TIMEOUT=120

# Maximum steps per action loop invocation (default 30).
MAX_LOOP_STEPS=30
